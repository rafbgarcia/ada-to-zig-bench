{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["ts", "elapsed_seconds", "phase", "stage_index", "target_requests_per_second", "sent_per_second", "received_per_second", "errors_per_second", "p99_latency_ms"],
  "properties": {
    "ts": { "type": "string" },
    "elapsed_seconds": { "type": "integer" },
    "elapsed_ms": { "type": "integer", "minimum": 0 },
    "work_mode": { "type": "string", "enum": ["open-loop", "fixed-work"] },
    "phase": { "type": "string" },
    "stage_index": { "type": "integer" },
    "target_requests_per_second": { "type": "integer", "minimum": 0 },
    "payload_bytes": { "type": "integer", "minimum": 0 },
    "in_flight": { "type": "integer", "minimum": 0 },
    "scheduled": { "type": "integer", "minimum": 0 },
    "dispatched": { "type": "integer", "minimum": 0 },
    "sent": { "type": "integer" },
    "received": { "type": "integer" },
    "errors": { "type": "integer" },
    "dispatch_misses": { "type": "integer" },
    "scheduled_per_second": { "type": "integer", "minimum": 0 },
    "dispatched_per_second": { "type": "integer", "minimum": 0 },
    "sent_per_second": { "type": "integer" },
    "received_per_second": { "type": "integer" },
    "errors_per_second": { "type": "integer" },
    "dispatch_misses_per_second": { "type": "integer" },
    "p50_latency_ms": { "type": "number" },
    "p90_latency_ms": { "type": "number" },
    "p99_latency_ms": { "type": "number" },
    "max_latency_ms": { "type": "number" }
  }
}

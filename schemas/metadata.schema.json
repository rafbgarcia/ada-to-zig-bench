{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "server", "url", "client_connections", "payload_bytes", "payload_sweep_seconds", "target_requests_per_second", "started_at"],
  "properties": {
    "id": { "type": "string" },
    "server": { "type": "string" },
    "language": { "type": ["string", "null"] },
    "runtime": { "type": ["string", "null"] },
    "toolchains": { "type": "array", "items": { "type": "string" } },
    "implementation": { "type": ["string", "null"] },
    "concurrency": { "type": ["string", "null"] },
    "suite": { "type": "string" },
    "server_command": { "type": "string" },
    "url": { "type": "string" },
    "urls": { "type": "array", "items": { "type": "string" } },
    "client_connections": { "type": "integer", "minimum": 1 },
    "payload_bytes": { "type": "integer", "minimum": 0 },
    "payload_sweep_bytes": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
    "payload_sweep_seconds": { "type": "integer", "minimum": 1 },
    "target_requests_per_second": { "type": "integer", "minimum": 0 },
    "target_messages_per_second": { "type": "integer", "minimum": 0 },
    "connection_retries": { "type": "integer", "minimum": 0 },
    "connection_retry_delay": { "type": "string" },
    "connection_retry_delay_ms": { "type": "integer", "minimum": 0 },
    "started_at": { "type": "string" },
    "git_commit": { "type": "string" },
    "benchmark_recommendations": { "type": "object" },
    "infrastructure": { "type": "object" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["ts", "elapsed_seconds", "pid", "cpu_percent", "rss_bytes", "rss_mb"],
  "properties": {
    "ts": { "type": "string" },
    "elapsed_seconds": { "type": "integer" },
    "pid": { "type": "integer" },
    "cpu_percent": { "type": "number" },
    "rss_bytes": { "type": "integer" },
    "rss_mb": { "type": "number" },
    "threads": { "type": "integer" },
    "open_fds": { "type": "integer" },
    "tcp_sockets": { "type": "integer" },
    "tcp_established": { "type": "integer" },
    "tcp_listen": { "type": "integer" },
    "tcp_close_wait": { "type": "integer" },
    "tcp_listen_overflows": { "type": "integer", "minimum": 0 },
    "tcp_listen_drops": { "type": "integer", "minimum": 0 },
    "tcp_backlog_drop": { "type": "integer", "minimum": 0 },
    "tcp_req_q_full_do_cookies": { "type": "integer", "minimum": 0 },
    "tcp_req_q_full_drop": { "type": "integer", "minimum": 0 },
    "tcp_syncookies_sent": { "type": "integer", "minimum": 0 },
    "tcp_syncookies_recv": { "type": "integer", "minimum": 0 },
    "tcp_syncookies_failed": { "type": "integer", "minimum": 0 },
    "tcp_embryonic_rsts": { "type": "integer", "minimum": 0 },
    "error": { "type": "string" }
  }
}

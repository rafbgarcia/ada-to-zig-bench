with "gnatcoll";

project Bench_Ada_Gnat is
   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("server.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-O3", "-gnat2022");
   end Compiler;

   package Builder is
      for Executable ("server.adb") use "server";
   end Builder;
end Bench_Ada_Gnat;

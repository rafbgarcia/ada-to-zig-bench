{
  "id": "c-libmicrohttpd",
  "language": "C",
  "runtime": "C + libmicrohttpd + jansson",
  "suite": "http-json",
  "toolchains": ["c"],
  "implementation": "libmicrohttpd + jansson",
  "concurrency": "thread-pool",
  "install": "cc -O3 -std=c11 -Wall -Wextra -o server src/server.c $(pkg-config --cflags --libs libmicrohttpd jansson)",
  "run": "./server"
}
